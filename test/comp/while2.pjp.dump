INPUT:
write "hello" .. ", " .. "world";

int c;
c = 10;

write c;

int i;
int j;

i = 0;

while (i < c)
{
    j = 0;

    while (j < i)
    {
        if (j % 2 == 0)
        {
            write "  " .. "j := " .. j ;
        }
        else    
            write "    " .. "j = " .. j ;

        j = j + 1;
    }

    write 'i = ' .. i;

    i = i + 1;
}



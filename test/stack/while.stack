; decl
push I 0
save a
push I 0
save b
; cycle
label 0
load a
push I 10
lt I
fjmp 1
	; block
		; write
		push S "a="
		load a
		print 2
		; expr stmt
		load a
		push I 1
		add I
		save a
		load a
		pop
jmp 0
label 1
; expr stmt
push I 0
save a
load a
pop
; read
read I
save b
; cycle
label 2
load a
load b
lt I
fjmp 3
	; block
		; write
		push S "a="
		load a
		push S ", b="
		load b
		print 4
		; expr stmt
		load a
		push I 1
		add I
		save a
		load a
		pop
jmp 2
label 3
